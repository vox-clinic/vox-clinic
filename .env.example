# Database (Supabase PostgreSQL)
# Use PgBouncer port (6543) for runtime with connection_limit to avoid pool exhaustion
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?connection_limit=15&pool_timeout=10"
# Direct connection (port 5432) for migrations/schema push only
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"

# Anthropic Claude API
ANTHROPIC_API_KEY="sk-ant-your-api-key-here"

# OpenAI Whisper API
OPENAI_API_KEY="sk-your-api-key-here"

# Supabase
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT_REF].supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# Clerk Authentication
CLERK_WEBHOOK_SECRET="whsec_your-webhook-secret"
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_your-key"
CLERK_SECRET_KEY="sk_test_your-key"

# Clerk Routes
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/onboarding"

# Email (Resend) — optional, needed for email reminders
RESEND_API_KEY="re_your-api-key"

# Cron Secret — optional, used to authenticate cron-triggered reminder endpoints
CRON_SECRET="your-cron-secret"

# Encryption Key — required if using WhatsApp integration (AES-256-GCM for token encryption)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# Daily.co — video teleconsulta
DAILY_API_KEY=
DAILY_WEBHOOK_SECRET=

# Upstash Redis — optional, serverless caching (graceful fallback if not set)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Inngest — optional, background job processing (graceful fallback to inline if not set)
# Local dev: set INNGEST_DEV=1 and run `npx inngest-cli@latest dev -u http://localhost:3000/api/inngest`
# Production: set INNGEST_EVENT_KEY and INNGEST_SIGNING_KEY from Inngest Cloud dashboard
INNGEST_DEV=1
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Stripe — optional, subscription billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=

# WhatsApp — optional, webhook verification token
WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# Superadmin — optional, comma-separated emails for superadmin access
SUPERADMIN_EMAILS=

# App URL — optional, defaults to https://app.voxclinic.com
NEXT_PUBLIC_APP_URL=

# Sentry — optional, error monitoring (graceful: disabled if DSN not set)
# Get DSN from https://sentry.io → Project Settings → Client Keys
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
